# Supabase — find these in your project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed for the seed script (Settings → API → service_role key).
# Keep this SECRET — never commit it or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The email/password of an existing user to attach seeded demo data to.
# Create this user via the app signup first, then run `npm run seed`.
SEED_USER_EMAIL=demo@example.com
